{
  "name": "scoreboard",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">= 24.0.0",
    "pnpm": ">= 10.0.0"
  },
  "scripts": {
    "start": "pnpm -r --parallel run start",
    "prod": "pnpm --filter=@sthack/scoreboard-server run prod",
    "build": "pnpm -r run build",
    "build:scoreboard": "pnpm run build:sb:prepare && pnpm run build:sb:server && pnpm run build:sb:client",
    "build:sb:prepare": "rm -rf dist && mkdir -p dist",
    "build:sb:client": "pnpm -r run build",
    "build:sb:server": "pnpm --filter @sthack/scoreboard-server --prod deploy --legacy ./dist",
    "build:HoF": "pnpm --filter=@sthack/scoreboard-hall-of-fame run build",
    "ts-check": "pnpm -r run ts-check",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "format": "prettier -w .",
    "create-admin": "pnpm run --filter=@sthack/scoreboard-server create-admin"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
